  "onDateSelected": "{{\n  (() => {\n    const etd = dp_etd.selectedDate || \"\";\n    const dias = appsmith.store.booking_form?.dias_libres || \"\";\n\n    const retiro = etd && dias !== \"\"\n      ? moment(etd).subtract(Number(dias), \"days\").toISOString()\n      : \"\";\n\n    return storeValue(\"booking_form\", {\n      ...appsmith.store.booking_form,\n      etd: etd,\n      retiro_vacios: retiro,\n      eta_pod: \"\"\n    }).then(() => {\n      resetWidget(\"dp_eta_pod\", true);\n    });\n  })()\n}}",

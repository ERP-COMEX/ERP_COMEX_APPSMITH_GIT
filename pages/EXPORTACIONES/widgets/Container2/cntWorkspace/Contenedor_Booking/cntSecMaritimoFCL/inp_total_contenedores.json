  "needsErrorInfo": false,
  "onTextChanged": "{{\n  (() => {\n    const raw = inp_total_contenedores.text;\n\n    if (raw === \"\" || raw === null || raw === undefined) {\n      return storeValue(\"booking_form\", {\n        ...appsmith.store.booking_form,\n        total_contenedores: \"\"\n      });\n    }\n\n    const limpio = String(raw).replace(/\\D/g, \"\");\n    const numero = Math.min(Number(limpio || 0), 30);\n    const valor = numero >= 1 ? String(numero) : \"\";\n\n    return storeValue(\"booking_form\", {\n      ...appsmith.store.booking_form,\n      total_contenedores: valor\n    });\n  })()\n}}",

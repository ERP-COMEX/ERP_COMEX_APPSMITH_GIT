  "isRequired": "{{\n  (appsmith.store.booking_form?.total_contenedores || \"\") === \"\" ||\n  (\n    /^[0-9]+$/.test(appsmith.store.booking_form?.total_contenedores || \"\") &&\n    Number(appsmith.store.booking_form?.total_contenedores) >= 1 &&\n    Number(appsmith.store.booking_form?.total_contenedores) <= 30\n  )\n}}",

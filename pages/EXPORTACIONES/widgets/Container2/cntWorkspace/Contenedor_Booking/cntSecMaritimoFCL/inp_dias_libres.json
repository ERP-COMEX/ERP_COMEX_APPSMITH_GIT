  "onTextChanged": "{{\n  (() => {\n    const raw = inp_dias_libres.text;\n\n    const limpio = raw === \"\" || raw === null || raw === undefined\n      ? \"\"\n      : String(raw).replace(/\\D/g, \"\");\n\n    const numero = limpio === \"\"\n      ? \"\"\n      : Math.min(Math.floor(Number(limpio)), 30);\n\n    const dias = numero === \"\" ? \"\" : String(numero);\n\n    const etd = appsmith.store.booking_form?.etd || dp_etd.selectedDate || \"\";\n\n    const retiro = etd && dias !== \"\"\n      ? moment(etd).subtract(Number(dias), \"days\").toISOString()\n      : \"\";\n\n    return storeValue(\"booking_form\", {\n      ...appsmith.store.booking_form,\n      dias_libres: dias,\n      retiro_vacios: retiro\n    });\n  })()\n}}",

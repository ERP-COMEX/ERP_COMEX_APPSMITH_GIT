  "isRequired": "{{\n  (appsmith.store.booking_form?.dias_libres || \"\") === \"\" ||\n  (\n    /^[0-9]+$/.test(appsmith.store.booking_form?.dias_libres || \"\") &&\n    Number(appsmith.store.booking_form?.dias_libres) >= 0 &&\n    Number(appsmith.store.booking_form?.dias_libres) <= 30\n  )\n}}",

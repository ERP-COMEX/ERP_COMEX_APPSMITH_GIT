      "iconName": "edit",
      "id": "groupButton2",
      "index": 2,
      "isDisabled": false,
      "isVisible": true,
      "label": "EDITAR",
      "menuItems": {},
      "onClick": "{{\n  appsmith.store.current_booking_id\n    ? (\n        resetWidget(\"sl_ciudad_incoterm\", true),\n        resetWidget(\"sl_pol\", true),\n        resetWidget(\"sl_terminal_pol\", true),\n        resetWidget(\"sl_pod\", true),\n        resetWidget(\"sl_puerto_transbordo\", true),\n\n        storeValue(\"form_mode\", \"EDIT\"),\n        showAlert(\"Modo EDICIÓN activado.\", \"info\")\n      )\n    : showAlert(\"Primero debes cargar un registro desde la búsqueda.\", \"warning\")\n}}",
      "placement": "START",
      "widgetId": ""
    },
    "groupButton2yjtisccgj": {
      "buttonColor": "#1e3a8a",
      "buttonType": "SIMPLE",
      "iconName": "applications",
      "id": "groupButton2yjtisccgj",
      "index": 3,
      "isDisabled": false,
      "isSeparator": false,
      "isVisible": true,
      "itemType": "BUTTON",
      "label": "DUPLICAR",
      "menuItems": {},
      "onClick": "{{\n  (async () => {\n    const ok = await BookingForm_OLD_hastaFCL.duplicateFromSelectedRow();\n\n    if (!ok) return;\n\n    showAlert(\n      \"Duplicado listo. Ahora selecciona RÉGIMEN para generar el consecutivo.\",\n      \"info\"\n    );\n  })()\n}}",
      "placement": "START",
      "variant": "filled",
      "widgetId": "zv53k3uc92"
    },
    "groupButtondppikj6s3b": {
      "buttonColor": "#1e3a8a",
      "buttonType": "SIMPLE",
      "iconName": "floppy-disk",
      "id": "groupButtondppikj6s3b",
      "index": 4,
      "isDisabled": false,
      "isSeparator": false,
      "isVisible": true,
      "itemType": "BUTTON",
      "label": "GUARDAR",
      "menuItems": {},
      "onClick": "{{\n  (async () => {\n    const modoActual = appsmith.store.form_mode;\n    const form = appsmith.store.booking_form || {};\n\n    if (![\"NEW\", \"EDIT\"].includes(modoActual)) {\n      showAlert(\"Debes estar en modo NUEVO o EDICIÓN antes de guardar.\", \"warning\");\n      return;\n    }\n\n    if (!appsmith.store.tenant_id || !appsmith.store.user_id) {\n      showAlert(\"No existe contexto de usuario/tenant.\", \"error\");\n      return;\n    }\n\n    if (!form.exportador_id) {\n      showAlert(\"Debes seleccionar el exportador.\", \"error\");\n      return;\n    }\n\n    if (!form.cliente_id) {\n      showAlert(\"Debes seleccionar el cliente.\", \"error\");\n      return;\n    }\n\n    if (!form.tipo_operacion_exportacion_id) {\n      showAlert(\"Debes seleccionar el tipo de operación.\", \"error\");\n      return;\n    }\n\n    if (!form.operacion_no) {\n      showAlert(\"No existe número de operación.\", \"error\");\n      return;\n    }\n\n    if (!form.modalidad_transporte_id) {\n      showAlert(\"Debes seleccionar el medio de transporte.\", \"error\");\n      return;\n    }\n\n    try {\n      const exportacion = await bk_upsert_exportacion.run();\n      const exportacionId = exportacion?.[0]?.id || \"\";\n\n      if (!exportacionId) {\n        showAlert(\"No se pudo obtener exportacion_id.\", \"error\");\n        return;\n      }\n\n      await storeValue(\"current_exportacion_id\", exportacionId);\n\n      const booking = await bk_upsert_booking.run();\n      const bookingId = booking?.[0]?.id || \"\";\n\n      if (!bookingId) {\n        showAlert(\"No se pudo obtener booking_id.\", \"error\");\n        return;\n      }\n\n      await storeValue(\"current_booking_id\", bookingId);\n      await storeValue(\"current_operacion_no\", form.operacion_no);\n\n      await storeValue(\"booking_form\", {\n        ...appsmith.store.booking_form,\n        exportacion_id: exportacionId,\n        booking_id: bookingId\n      });\n\n      try {\n        if (q_sync_operacion_consecutivo?.run && typeof q_sync_operacion_consecutivo.run === \"function\") {\n          await q_sync_operacion_consecutivo.run();\n        }\n      } catch (syncErr) {\n        showAlert(\"Guardado correcto, pero no se pudo sincronizar el consecutivo.\", \"warning\");\n      }\n\n      await storeValue(\"form_mode\", \"VIEW\");\n\n      try {\n        if (q_booking_detail?.run && typeof q_booking_detail.run === \"function\") {\n          await q_booking_detail.run();\n        }\n      } catch (detailErr) {}\n\n      try {\n        if (q_booking_search?.run && typeof q_booking_search.run === \"function\") {\n          await q_booking_search.run();\n        }\n      } catch (searchErr) {}\n\n      showAlert(\n        modoActual === \"NEW\"\n          ? \"Nueva operación guardada correctamente.\"\n          : \"Cambios guardados correctamente.\",\n        \"success\"\n      );\n\n    } catch (err) {\n      showAlert(\"Error al guardar: \" + JSON.stringify(err), \"error\");\n    }\n  })()\n}}",
      "placement": "START",
      "variant": "filled",
      "widgetId": "d8jzoo2nsu"
    },

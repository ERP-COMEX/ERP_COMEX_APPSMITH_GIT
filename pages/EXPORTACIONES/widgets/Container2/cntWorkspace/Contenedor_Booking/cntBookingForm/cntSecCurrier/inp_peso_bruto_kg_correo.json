  "errorMessage": "{{ \"Ingrese un peso bruto válido, mayor a 0 y no menor al peso neto.\" }}",
  "iconAlign": "left",
  "inputType": "NUMBER",
  "isDisabled": "{{\n  appsmith.store.form_mode === \"VIEW\"\n  || !(\n    (appsmith.store.booking_form?.modalidad_transporte_label || sl_transporte.selectedOptionLabel || \"\")\n      .toUpperCase()\n      .includes(\"CORREO\")\n  )\n}}",
  "isLoading": false,
  "isRequired": "{{\n  sl_transporte.selectedOptionLabel === 'CORREO'\n}}",
  "isVisible": true,
  "key": "ft6ryaeagd",
  "label": "TOTAL PESO BRUTO Kg",
  "labelAlignment": "left",
  "labelPosition": "Top",
  "labelStyle": "BOLD",
  "labelTextColor": "#1e3a8a",
  "labelTextSize": "0.875rem",
  "labelWidth": 5,
  "leftColumn": 36,
  "maxDynamicHeight": 9000,
  "minDynamicHeight": 4,
  "minWidth": 450,
  "mobileBottomRow": 15,
  "mobileLeftColumn": 0,
  "mobileRightColumn": 6,
  "mobileTopRow": 8,
  "needsErrorInfo": false,
  "onTextChanged": "{{\n  (() => {\n    const raw = inp_peso_bruto_kg_correo.text;\n\n    if (raw === \"\" || raw === null || raw === undefined) {\n      return BookingForm.setFields({\n        peso_bruto_kg_correo: \"\"\n      });\n    }\n\n    let limpio = String(raw)\n      .replace(\",\", \".\")\n      .replace(/[^0-9.]/g, \"\");\n\n    const partes = limpio.split(\".\");\n    if (partes.length > 2) {\n      limpio = partes[0] + \".\" + partes.slice(1).join(\"\");\n    }\n\n    if (limpio.startsWith(\".\")) {\n      limpio = \"0\" + limpio;\n    }\n\n    const numero = Number(limpio);\n\n    const neto =\n      Number(appsmith.store.booking_form?.peso_neto_kg_correo || 0);\n\n    const valor =\n      limpio !== \"\"\n      && !isNaN(numero)\n      && numero > 0\n      && numero >= neto\n        ? limpio\n        : \"\";\n\n    return BookingForm.setFields({\n      peso_bruto_kg_correo: valor\n    });\n  })()\n}}",
  "originalBottomRow": 16,
  "originalTopRow": 9,
  "parentColumnSpace": 16.375,
  "parentId": "jdc5zt6jv5",
  "parentRowSpace": 10,
  "renderMode": "CANVAS",
  "resetOnSubmit": true,
  "responsiveBehavior": "fill",
  "rightColumn": 47,
  "shouldAllowAutofill": false,
  "shouldScrollContents": true,
  "showStepArrows": false,
  "topRow": 9,
  "type": "INPUT_WIDGET_V2",
  "validation": "{{\n  (appsmith.store.booking_form?.peso_bruto_kg_correo || \"\") === \"\"\n  ||\n  (\n    /^[0-9]+(\\.[0-9]{1,3})?$/.test(\n      appsmith.store.booking_form?.peso_bruto_kg_correo || \"\"\n    )\n    &&\n    Number(appsmith.store.booking_form?.peso_bruto_kg_correo) > 0\n    &&\n    (\n      !appsmith.store.booking_form?.peso_neto_kg_correo\n      ||\n      Number(appsmith.store.booking_form?.peso_bruto_kg_correo)\n      >=\n      Number(appsmith.store.booking_form?.peso_neto_kg_correo)\n    )\n  )\n}}",
  "version": 2,
  "widgetId": "8v8uzt1c7j",
  "widgetName": "inp_peso_bruto_kg_correo"
}
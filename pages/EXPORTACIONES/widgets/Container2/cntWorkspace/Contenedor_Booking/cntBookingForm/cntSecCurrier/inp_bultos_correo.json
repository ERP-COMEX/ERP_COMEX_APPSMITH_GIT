  "onTextChanged": "{{\n  (() => {\n    const raw = inp_bultos_correo.text;\n\n    if (raw === \"\" || raw === null || raw === undefined) {\n      return BookingForm.setFields({\n        bultos_correo: \"\"\n      });\n    }\n\n    const limpio = String(raw).replace(/\\D/g, \"\");\n    const numero = Number(limpio || 0);\n    const valor = numero >= 1 ? String(numero) : \"\";\n\n    return BookingForm.setFields({\n      bultos_correo: valor\n    });\n  })()\n}}",

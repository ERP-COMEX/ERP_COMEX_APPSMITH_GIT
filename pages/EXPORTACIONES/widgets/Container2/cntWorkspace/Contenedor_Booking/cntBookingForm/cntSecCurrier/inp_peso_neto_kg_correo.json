  "needsErrorInfo": false,
  "onTextChanged": "{{\n  (() => {\n    const raw = inp_peso_neto_kg_correo.text;\n\n    if (raw === \"\" || raw === null || raw === undefined) {\n      return BookingForm.setFields({\n        peso_neto_kg_correo: \"\"\n      });\n    }\n\n    let limpio = String(raw)\n      .replace(\",\", \".\")\n      .replace(/[^0-9.]/g, \"\");\n\n    const partes = limpio.split(\".\");\n    if (partes.length > 2) {\n      limpio = partes[0] + \".\" + partes.slice(1).join(\"\");\n    }\n\n    if (limpio.startsWith(\".\")) {\n      limpio = \"0\" + limpio;\n    }\n\n    const numero = Number(limpio);\n\n    const valor =\n      limpio !== \"\" && !isNaN(numero) && numero > 0\n        ? limpio\n        : \"\";\n\n    return BookingForm.setFields({\n      peso_neto_kg_correo: valor\n    });\n  })()\n}}",
  "originalBottomRow": 16,

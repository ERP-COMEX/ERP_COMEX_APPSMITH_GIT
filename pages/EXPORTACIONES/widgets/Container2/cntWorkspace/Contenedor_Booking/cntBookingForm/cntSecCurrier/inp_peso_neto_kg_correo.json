  "isDisabled": "{{\n  appsmith.store.form_mode === \"VIEW\"\n  || !(\n    (appsmith.store.booking_form?.modalidad_transporte_label || sl_transporte.selectedOptionLabel || \"\")\n      .toUpperCase()\n      .includes(\"CORREO\")\n  )\n}}",
  "isLoading": false,
  "isRequired": "{{\n  (appsmith.store.booking_form?.peso_neto_kg_correo || \"\") === \"\"\n  ||\n  (\n    /^[0-9]+(\\.[0-9]{1,3})?$/.test(appsmith.store.booking_form?.peso_neto_kg_correo || \"\")\n    &&\n    Number(appsmith.store.booking_form?.peso_neto_kg_correo) > 0\n  )\n}}",

  "isDisabled": "{{\n  appsmith.store.form_mode === \"VIEW\"\n  || !(\n    (appsmith.store.booking_form?.modalidad_transporte_label || sl_transporte.selectedOptionLabel || \"\")\n      .toUpperCase()\n      .includes(\"CAR\")\n  )\n}}",
  "isLoading": false,
  "isRequired": "{{\n  (appsmith.store.booking_form?.total_vehiculos_ter || \"\") === \"\" ||\n  (\n    /^[0-9]+$/.test(appsmith.store.booking_form?.total_vehiculos_ter || \"\") &&\n    Number(appsmith.store.booking_form?.total_vehiculos_ter) >= 1\n  )\n}}",

  "onTextChanged": "{{\n  (() => {\n    const raw = inp_viaje_lcl.text;\n\n    if (raw === \"\" || raw === null || raw === undefined) {\n      return storeValue(\"booking_form\", {\n        ...appsmith.store.booking_form,\n        viaje_lcl: \"\"\n      });\n    }\n\n    const limpio = String(raw)\n      .toUpperCase()\n      .replace(/\\s+/g, \"\")\n      .replace(/[^A-Z0-9\\-\\/]/g, \"\")\n      .slice(0, 30);\n\n    return storeValue(\"booking_form\", {\n      ...appsmith.store.booking_form,\n      viaje_lcl: limpio\n    });\n  })()\n}}",

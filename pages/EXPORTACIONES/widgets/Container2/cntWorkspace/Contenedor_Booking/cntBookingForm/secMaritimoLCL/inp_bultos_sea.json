  "onTextChanged": "{{\n  (() => {\n    const raw = inp_bultos_sea.text;\n\n    if (raw === \"\" || raw === null || raw === undefined) {\n      return storeValue(\"booking_form\", {\n        ...appsmith.store.booking_form,\n        bultos_sea: \"\"\n      });\n    }\n\n    const limpio = String(raw).replace(/\\D/g, \"\");\n    const numero = Number(limpio || 0);\n    const valor = numero >= 1 ? String(numero) : \"\";\n\n    return storeValue(\"booking_form\", {\n      ...appsmith.store.booking_form,\n      bultos_sea: valor\n    });\n  })()\n}}",

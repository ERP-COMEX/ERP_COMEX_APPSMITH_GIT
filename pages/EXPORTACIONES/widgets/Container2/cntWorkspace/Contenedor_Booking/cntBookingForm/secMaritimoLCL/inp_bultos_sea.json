  "isRequired": "{{\n  (appsmith.store.booking_form?.bultos_sea || \"\") === \"\" ||\n  (\n    /^[0-9]+$/.test(appsmith.store.booking_form?.bultos_sea || \"\") &&\n    Number(appsmith.store.booking_form?.bultos_sea) >= 1\n  )\n}}",

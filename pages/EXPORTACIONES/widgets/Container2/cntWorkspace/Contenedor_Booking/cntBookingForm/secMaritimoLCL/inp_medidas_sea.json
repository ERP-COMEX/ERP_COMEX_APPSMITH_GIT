  "onTextChanged": "{{\n  (() => {\n    const raw = inp_medidas_sea.text;\n\n    if (raw === \"\" || raw === null || raw === undefined) {\n      return storeValue(\"booking_form\", {\n        ...appsmith.store.booking_form,\n        medidas_sea: \"\"\n      });\n    }\n\n    const limpio = String(raw)\n      .toUpperCase()\n      .replace(/\\s+/g, \" \")\n      .trim()\n      .slice(0, 100);\n\n    return storeValue(\"booking_form\", {\n      ...appsmith.store.booking_form,\n      medidas_sea: limpio\n    });\n  })()\n}}",

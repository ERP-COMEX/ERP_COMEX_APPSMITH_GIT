  "isRequired": "{{\n  (appsmith.store.booking_form?.medidas_sea || \"\") === \"\" ||\n  (\n    (appsmith.store.booking_form?.medidas_sea || \"\").length >= 3 &&\n    (appsmith.store.booking_form?.medidas_sea || \"\").length <= 100\n  )\n}}",

  "minWidth": 450,
  "mobileBottomRow": 27,
  "mobileLeftColumn": 0,
  "mobileRightColumn": 18,
  "mobileTopRow": 20,
  "needsErrorInfo": false,
  "onTextChanged": "{{\n  (() => {\n    const raw = inp_cbm_sea.text;\n\n    if (raw === \"\" || raw === null || raw === undefined) {\n      return storeValue(\"booking_form\", {\n        ...appsmith.store.booking_form,\n        cbm_sea: \"\"\n      });\n    }\n\n    let limpio = String(raw)\n      .replace(\",\", \".\")\n      .replace(/[^0-9.]/g, \"\");\n\n    const partes = limpio.split(\".\");\n    if (partes.length > 2) {\n      limpio = partes[0] + \".\" + partes.slice(1).join(\"\");\n    }\n\n    if (limpio.startsWith(\".\")) {\n      limpio = \"0\" + limpio;\n    }\n\n    let numero = Number(limpio);\n\n    if (isNaN(numero) || numero <= 0) {\n      numero = \"\";\n    } else {\n      numero = Number(numero.toFixed(3));\n    }\n\n    return storeValue(\"booking_form\", {\n      ...appsmith.store.booking_form,\n      cbm_sea: numero === \"\" ? \"\" : String(numero)\n    });\n  })()\n}}",

  "errorMessage": "{{ \"Ingrese un CBM válido, mayor a cero y con máximo 3 decimales.\" }}",
  "iconAlign": "left",
  "inputType": "NUMBER",
  "isDisabled": "{{\n  appsmith.store.form_mode === \"VIEW\"\n  || !(\n    (appsmith.store.booking_form?.modalidad_transporte_label || sl_transporte.selectedOptionLabel || \"\")\n      .toUpperCase()\n      .includes(\"MAR\")\n    && (appsmith.store.booking_form?.tipo_carga_label || sl_tipo_carga.selectedOptionLabel || \"\")\n      .toUpperCase()\n      .includes(\"LCL\")\n  )\n}}",
  "isLoading": false,
  "isRequired": "{{\n  (appsmith.store.booking_form?.cbm_sea || \"\") === \"\" ||\n  (\n    /^[0-9]+(\\.[0-9]{1,3})?$/.test(appsmith.store.booking_form?.cbm_sea || \"\") &&\n    Number(appsmith.store.booking_form?.cbm_sea) > 0\n  )\n}}",
  "isVisible": true,
  "key": "kkyivtxqwg",
  "label": "CBM",
  "labelAlignment": "left",
  "labelPosition": "Top",
  "labelStyle": "BOLD",
  "labelTextColor": "#1e3a8a",
  "labelTextSize": "0.875rem",
  "labelWidth": 5,

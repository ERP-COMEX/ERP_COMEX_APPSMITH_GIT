  "onOptionChange": "{{\n\nappsmith.store.cv_loading_item_edit\n    ? null:\n  (() => {\n    const p = (qCvItemCodigoDropdown.data || []).find(\n      x => x.value === slCvItemCodigo.selectedOptionValue\n    );\n\n    if (!p) {\n      showAlert(\"No se encontró el producto seleccionado.\", \"warning\");\n      return;\n    }\n\n    storeValue(\"cv_item_producto\", {\n      producto_id: p.producto_id,\n      codigo_producto: p.codigo_interno,\n      descripcion: p.descripcion_corta || p.descripcion_completa,\n      marca: p.marca,\n      subpartida: p.subpartida,\n      partida_codigo: p.partida_codigo,\n      partida_descripcion: p.partida_descripcion\n    });\n\n    resetWidget(\"slCvItemEmpaque\", true);\n    storeValue(\"cv_item_empaque\", null);\n    qCvItemEmpaqueDropdown.run();\n  })()\n}}",

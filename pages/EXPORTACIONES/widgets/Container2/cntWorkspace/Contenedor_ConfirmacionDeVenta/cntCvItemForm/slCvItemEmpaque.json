  "onOptionChange": "{{\n\nappsmith.store.cv_loading_item_edit\n    ? null:\n  (() => {\n    const e = (qCvItemEmpaqueDropdown.data || []).find(\n      x => x.value === slCvItemEmpaque.selectedOptionValue\n    );\n\n    if (!e) {\n      showAlert(\"No se encontró el empaque seleccionado.\", \"warning\");\n      return;\n    }\n\n    storeValue(\"cv_item_empaque\", {\n      empaque_id: e.empaque_id,\n      codigo_empaque: e.codigo_empaque,\n      nombre_empaque: e.nombre_empaque,\n      presentacion_comercial: e.presentacion_comercial,\n      tipo_empaque: e.tipo_empaque,\n      unidad_comercial: e.unidad_comercial,\n      unidad_dian: e.unidad_dian,\n      cantidad_por_empaque: Number(e.cantidad_por_empaque || 1),\n      peso_neto_unitario: Number(e.peso_neto_empaque_kg || 0),\n      peso_bruto_unitario: Number(e.peso_bruto_empaque_kg || 0),\n      volumen_unitario: Number(e.volumen_empaque_m3 || 0)\n    });\n  })()\n}}",

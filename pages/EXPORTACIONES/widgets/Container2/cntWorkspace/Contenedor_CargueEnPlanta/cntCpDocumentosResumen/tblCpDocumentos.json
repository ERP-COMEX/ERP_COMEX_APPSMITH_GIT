  "onRowSelected": "{{\n(async () => {\n  // Evita que al cambiar/limpiar operación se cargue una proforma residual\n  if (appsmith.store.cv_loading_operacion) {\n    return;\n  }\n\n  // Bloquea cambio de proforma si hay cambios pendientes sin guardar\n  if (appsmith.store.cv_has_pending_changes) {\n    showAlert(\n      \"Tienes cambios pendientes. Guarda o cancela antes de cambiar de proforma.\",\n      \"warning\"\n    );\n    return;\n  }\n\n  const row = tblCvProformasResumen.selectedRow || null;\n\n  // Sin fila real seleccionada: limpiar proforma y salir\n  if (!row || !row.id) {\n    await JS_CvForm.resetProformaForm();\n    return;\n  }\n\n  // Sin operación activa: limpiar proforma y salir\n  if (!appsmith.store.cv_exportacion_id) {\n    await JS_CvForm.resetProformaForm();\n    return;\n  }\n\n  // Si la proforma no pertenece a la operación activa: limpiar y salir\n  if (row.exportacion_id !== appsmith.store.cv_exportacion_id) {\n    await JS_CvForm.resetProformaForm();\n    return;\n  }\n\n  await storeValue(\"cv_form_mode\", \"VIEW\");\n  await storeValue(\"cv_proforma_id\", row.id);\n\n  if (qCvProformaCabecera?.run) {\n    await qCvProformaCabecera.run();\n  }\n\n  if (qCvProformaDetalle?.run) {\n    await qCvProformaDetalle.run();\n  }\n\n  const cab = qCvProformaCabecera.data?.[0] || null;\n  const det = qCvProformaDetalle.data || [];\n\n  // Si no encontró cabecera, no debe dejar residuos\n  if (!cab || cab.id !== row.id) {\n    await JS_CvForm.resetProformaForm();\n    return;\n  }\n\n  await storeValue(\"cv_proforma_loaded\", cab);\n  await storeValue(\"cv_items_proforma\", det);\n\n  await JS_CvForm.clearItemForm();\n  await JS_CvForm.loadProforma();\n})();\n}}",
